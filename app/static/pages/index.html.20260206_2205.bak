<!DOCTYPE html>
<html lang="en" data-theme="light">

<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>RUMBO - Panel Empresarial</title>

    <!-- PWA Meta Tags -->
    <link rel="manifest" href="/static/manifest.json">
    <meta name="theme-color" content="#6366f1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <link rel="apple-touch-icon" href="/static/images/icon-192x192.png">

    <!-- Fonts -->
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link
        href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800&family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@400;500&display=swap"
        rel="stylesheet">

    <!-- CSS Dependencies -->
    <!-- CSS Dependencies -->
    <link href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" rel="stylesheet">
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/css/bootstrap.min.css" rel="stylesheet">
    <!-- Frappe Gantt CSS -->
    <link href="https://cdn.jsdelivr.net/npm/frappe-gantt@0.6.1/dist/frappe-gantt.css" rel="stylesheet">

    <!-- Custom Styles -->
    <link href="../css/design-system.css?v=13" rel="stylesheet">
    <link href="../css/layout-shim.css?v=13" rel="stylesheet">
    <link href="../css/styles.css?v=13" rel="stylesheet">
    <link href="../css/kpi-cards.css?v=1" rel="stylesheet">
    <link href="../css/kanban-premium.css?v=1" rel="stylesheet">
    <!-- Tabla Premium RUMBO -->
    <link href="../css/tabla-premium-rumbo.css" rel="stylesheet">

    <!-- Third Party JS -->
    <script src="https://cdn.jsdelivr.net/npm/chart.js@4.4.0/dist/chart.umd.min.js"></script>
    <script src="https://cdn.jsdelivr.net/npm/frappe-gantt@0.6.1/dist/frappe-gantt.min.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/html2pdf.js/0.10.1/html2pdf.bundle.min.js"></script>
    <script src="https://d3js.org/d3.v7.min.js"></script>
</head>

<body class="bg-body-tertiary">
    <!-- Navbar injected by navigation.js -->

    <!-- Toast Container -->

    <main class="container-fluid pt-1 pb-0" style="margin-top: 60px;">

        <div class="container animate-fade-in-up">
            <!-- Header -->
            <div class="d-flex justify-content-between align-items-center mb-2">
                <div>
                    <h1 class="h3 font-weight-bold mb-1">Panel de RUMBO</h1>
                    <p class="text-muted small mb-0">Sistema de Gestión de Proyectos Empresariales</p>
                </div>
                <div class="d-flex align-items-center gap-3">
                    <div id="connection-status" class="d-none d-md-flex align-items-center gap-2 small">
                        <span class="badge bg-success rounded-pill">● En línea</span>
                    </div>
                </div>
            </div>

            <!-- TABS NAVIGATION (SPA) -->
            <ul class="nav nav-tabs premium-tabs mb-0" id="dashboardTabs" role="tablist">
                <li class="nav-item" role="presentation">
                    <button class="nav-link active" id="overview-tab" data-bs-toggle="tab" data-bs-target="#overview"
                        type="button" role="tab" aria-selected="true">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="me-2">
                            <path d="M3 10H10V3H3V10ZM3 21H10V14H3V21ZM14 21H21V10H14V21ZM14 3V7H21V3H14Z"
                                stroke="currentColor" stroke-width="2" />
                        </svg>
                        Resumen
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tasks-tab" data-bs-toggle="tab" data-bs-target="#tasks" type="button"
                        role="tab" aria-selected="false">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="me-2">
                            <path
                                d="M9 11L12 14L22 4M21 12V19C21 19.5304 20.7893 20.0391 20.4142 20.4142C20.0391 20.7893 19.5304 21 19 21H5C4.46957 21 3.96086 20.7893 3.58579 20.4142C3.21071 20.0391 3 19.5304 3 19V5C3 4.46957 3.21071 3.96086 3.58579 3.58579C3.96086 3.21071 4.46957 3 5 3H16"
                                stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        Tareas
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="capacity-tab" data-bs-toggle="tab" data-bs-target="#capacity"
                        type="button" role="tab" aria-selected="false">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="me-2">
                            <path
                                d="M16.2426 6.34317L14.8284 4.92896C13.5621 3.66262 12 3 12 3C12 3 6 9 6 15C6 18.3137 8.68629 21 12 21C15.3137 21 18 18.3137 18 15C18 13 17 11 16.2426 6.34317Z"
                                stroke="currentColor" stroke-width="2" />
                            <path d="M12 21V15M12 15L14.5 12" stroke="currentColor" stroke-width="2"
                                stroke-linecap="round" />
                        </svg>
                        Capacidad
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="tracking-tab" data-bs-toggle="tab" data-bs-target="#tracking"
                        type="button" role="tab" aria-selected="false">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="me-2">
                            <path
                                d="M12 8V12L15 15M21 12C21 16.9706 16.9706 21 12 21C7.02944 21 3 16.9706 3 12C3 7.02944 7.02944 3 12 3C16.9706 3 21 7.02944 21 12Z"
                                stroke="currentColor" stroke-width="2" />
                        </svg>
                        Registro de Tiempo
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="timeline-tab" data-bs-toggle="tab" data-bs-target="#timeline"
                        type="button" role="tab" aria-selected="false">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="me-2">
                            <path
                                d="M8 7V3M16 7V3M7 11H17M5 21H19C20.1046 21 21 20.1046 21 19V7C21 5.89543 20.1046 5 19 5H5C3.89543 5 3 5.89543 3 7V19C3 20.1046 3.89543 21 5 21Z"
                                stroke="currentColor" stroke-width="2" />
                        </svg>
                        Cronología (Gantt)
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="scoreboard-tab" data-bs-toggle="tab" data-bs-target="#scoreboard"
                        type="button" role="tab" aria-selected="false">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="me-2">
                            <path
                                d="M9 12L11 14L15 10M3 5H21M5 5H19C20.1046 5 21 5.89543 21 7V19C21 20.1046 20.1046 21 19 21H5C3.89543 21 3 20.1046 3 19V7C3 5.89543 3.89543 5 5 5Z"
                                stroke="currentColor" stroke-width="2" />
                        </svg>
                        Tablero de Proyectos
                    </button>
                </li>
                <li class="nav-item" role="presentation">
                    <button class="nav-link" id="talent-tab" data-bs-toggle="tab" data-bs-target="#talent" type="button"
                        role="tab" aria-selected="false">
                        <svg width="18" height="18" viewBox="0 0 24 24" fill="none" class="me-2">
                            <path
                                d="M12 4.35417C12.5055 4.35417 12.9151 4.76375 12.9151 5.26929C12.9151 5.77482 12.5055 6.1844 12 6.1844C11.4945 6.1844 11.0849 5.77482 11.0849 5.26929C11.0849 4.76375 11.4945 4.35417 12 4.35417Z"
                                stroke="currentColor" />
                            <path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2" stroke="currentColor" stroke-width="2"
                                stroke-linecap="round" stroke-linejoin="round" />
                            <circle cx="9" cy="7" r="4" stroke="currentColor" stroke-width="2" stroke-linecap="round"
                                stroke-linejoin="round" />
                            <path d="M23 21v-2a4 4 0 0 0-3-3.87" stroke="currentColor" stroke-width="2"
                                stroke-linecap="round" stroke-linejoin="round" />
                            <path d="M16 3.13a4 4 0 0 1 0 7.75" stroke="currentColor" stroke-width="2"
                                stroke-linecap="round" stroke-linejoin="round" />
                        </svg>
                        Talento
                    </button>
                </li>
            </ul>

            <!-- TABS CONTENT -->
            <div class="tab-content" id="dashboardTabContent">

                <!-- TAB 1: OVERVIEW -->
                <div class="tab-pane fade show active" id="overview" role="tabpanel">



                    <!-- KPI HUD Strip -->
                    <div class="glass-card mb-2 flex items-center justify-between py-3 px-6 relative overflow-hidden"
                        id="scoreboard-container">
                        <div
                            class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-primary to-transparent opacity-50">
                        </div>

                        <div class="flex items-center gap-4 flex-1 border-r border-gray-200 dark:border-gray-700 pr-6">
                            <div class="p-2 bg-blue-50 dark:bg-blue-900/30 rounded-lg text-blue-600">
                                <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M19 11H5m14 0a2 2 0 012 2v6a2 2 0 01-2 2H5a2 2 0 01-2-2v-6a2 2 0 012-2m14 0V9a2 2 0 00-2-2M5 11V9a2 2 0 012-2m0 0V5a2 2 0 012-2h6a2 2 0 012 2v2M7 7h10">
                                    </path>
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500 font-semibold uppercase tracking-wider">Total de
                                    Tareas
                                </p>
                                <div class="flex items-baseline gap-2">
                                    <span class="text-2xl font-bold text-gray-900 dark:text-white"
                                        id="kpi-total-value">0</span>
                                    <span class="text-xs text-green-500 font-medium">Activas</span>
                                </div>
                            </div>
                        </div>

                        <div class="flex items-center gap-4 flex-1 px-6">
                            <div class="relative w-10 h-10 flex items-center justify-center">
                                <div class="absolute inset-0 rounded-full"
                                    style="background: conic-gradient(var(--color-success) 0% 0%, var(--color-gray-200) 0% 100%);"
                                    id="kpi-rate-ring"></div>
                                <div class="absolute inset-1 bg-white dark:bg-gray-800 rounded-full"></div>
                                <svg class="w-4 h-4 text-green-600 relative z-10" fill="none" viewBox="0 0 24 24"
                                    stroke="currentColor">
                                    <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                        d="M5 13l4 4L19 7" />
                                </svg>
                            </div>
                            <div>
                                <p class="text-xs text-gray-500 font-semibold uppercase tracking-wider">Tasa de
                                    Éxito
                                </p>
                                <div class="flex items-baseline gap-2">
                                    <span class="text-2xl font-bold text-gray-900 dark:text-white"
                                        id="kpi-rate-value">0%</span>
                                </div>
                            </div>
                        </div>


                    </div>



                    <!-- KPI Grid -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                        <!-- 1. Team Utilization -->
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 relative overflow-hidden group hover:shadow-md transition-all border border-gray-100 dark:border-gray-700">
                            <div class="flex justify-between items-start mb-4">
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider">Utilización del
                                    Equipo</div>
                                <div class="text-blue-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M17 20h5v-2a3 3 0 00-5.356-1.857M17 20H7m10 0v-2c0-.656-.126-1.283-.356-1.857M7 20H2v-2a3 3 0 015.356-1.857M7 20v-2c0-.656.126-1.283.356-1.857m0 0a5.002 5.002 0 019.288 0M15 7a3 3 0 11-6 0 3 3 0 016 0zm6 3a2 2 0 11-4 0 2 2 0 014 0zM7 10a2 2 0 11-4 0 2 2 0 014 0z">
                                        </path>
                                    </svg>
                                </div>
                            </div>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-bold text-gray-900 dark:text-gray-100"
                                    id="utilization-kpi">0.0%</span>
                            </div>
                        </div>

                        <!-- 2. Cost Efficiency (CPI) -->
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 relative overflow-hidden group hover:shadow-md transition-all border border-gray-100 dark:border-gray-700">
                            <div class="flex justify-between items-start mb-4">
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider">Eficiencia de
                                    Costos (CPI)</div>
                                <div class="text-yellow-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
                                        </path>
                                    </svg>
                                </div>
                            </div>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-bold text-gray-900 dark:text-gray-100"
                                    id="kpi-cpi-value">0.9</span>
                                <span class="text-xs font-semibold text-gray-500" id="kpi-cpi-status">At Risk (<
                                        1.0)</span>
                            </div>
                        </div>

                        <!-- 3. Final Projection (EAC) -->
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 relative overflow-hidden group hover:shadow-md transition-all border border-gray-100 dark:border-gray-700">
                            <div class="flex justify-between items-start mb-4">
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider">Proyección Final
                                    (EAC)</div>
                                <div class="text-blue-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M12 8c-1.657 0-3 .895-3 2s1.343 2 3 2 3 .895 3 2-1.343 2-3 2m0-8c1.11 0 2.08.402 2.599 1M12 8V7m0 1v8m0 0v1m0-1c-1.11 0-2.08-.402-2.599-1M21 12a9 9 0 11-18 0 9 9 0 0118 0z">
                                        </path>
                                    </svg>
                                </div>
                            </div>
                            <div class="flex flex-col">
                                <span class="text-3xl font-bold text-gray-900 dark:text-gray-100"
                                    id="kpi-eac-value">$111,696</span>
                                <span class="text-sm font-medium text-gray-500 flex items-center mt-1"
                                    id="kpi-eac-delta">
                                    +$11,696
                                    <svg class="w-3 h-3 ml-1" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M13 7h8m0 0v8m0-8l-8 8-4-4-6 6"></path>
                                    </svg>
                                </span>
                            </div>
                        </div>

                        <!-- 4. Schedule Performance (SPI) -->
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 relative overflow-hidden group hover:shadow-md transition-all border border-gray-100 dark:border-gray-700">
                            <div class="flex justify-between items-start mb-4">
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider">Desempeño
                                    Cronograma (SPI)</div>
                                <div class="text-gray-400">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M6 18L18 6M6 6l12 12"></path>
                                    </svg>
                                </div>
                            </div>
                            <div class="flex items-baseline justify-between">
                                <span class="text-4xl font-bold text-gray-900 dark:text-gray-100"
                                    id="kpi-spi-value">0.38</span>
                                <div class="text-right">
                                    <span class="block text-sm font-bold text-gray-900 dark:text-gray-100"
                                        id="kpi-spi-status">Retrasado</span>
                                    <span class="block text-xs text-gray-500" id="kpi-spi-delay">12.4 días</span>
                                </div>
                            </div>
                        </div>

                        <!-- 5. Cycle Time -->
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 relative overflow-hidden group hover:shadow-md transition-all border border-gray-100 dark:border-gray-700">
                            <div class="flex justify-between items-start mb-4">
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider">Cycle Time
                                    Promedio</div>
                                <div class="text-gray-400">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                </div>
                            </div>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-bold text-gray-900 dark:text-gray-100"
                                    id="kpi-cycle-value">0.0</span>
                                <span class="text-lg text-gray-500">días</span>
                            </div>
                            <span class="text-xs text-gray-400 mt-2 block" id="kpi-cycle-trend">→ 0 vs semana
                                anterior</span>
                        </div>

                        <!-- 6. Flow Efficiency -->
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 relative overflow-hidden group hover:shadow-md transition-all border border-gray-100 dark:border-gray-700">
                            <div class="flex justify-between items-start mb-4">
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider">Eficiencia de
                                    Flujo</div>
                                <div class="text-purple-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                                    </svg>
                                </div>
                            </div>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-bold text-gray-900 dark:text-gray-100"
                                    id="kpi-flow-value">0%</span>
                            </div>
                        </div>
                    </div>
                    <div id="kpi-cards-container" class="d-none"></div>

                    <!-- Analytics & Distribution (New Donut Charts) -->
                    <div class="row g-3 mb-2">
                        <div class="col-md-6">
                            <div class="glass-card h-100">
                                <div class="card-header">Tareas por Proyecto</div>
                                <div class="card-body">
                                    <canvas id="projectDonutChart" height="250"></canvas>
                                    <!-- Height managed by JS/CSS mostly -->
                                </div>
                            </div>
                        </div>
                        <div class="col-md-6">
                            <div class="glass-card h-100">
                                <div class="card-header">Tareas por Recurso</div>
                                <div class="card-body">
                                    <canvas id="resourceDonutChart" height="250"></canvas>
                                </div>
                            </div>
                        </div>
                    </div>

                    <!-- Main Charts -->
                    <!-- Main Charts -->
                    <!-- Main Charts (Stacked Vertically) -->
                    <div class="row g-3 mb-2">
                        <div class="col-12">
                            <div class="glass-card">
                                <div class="card-header">Estado del Portafolio de Proyectos</div>
                                <div class="card-body">
                                    <div class="chart-container" style="position: relative; height: 300px;">
                                        <canvas id="projectsChart"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                        <div class="col-12">
                            <div class="glass-card">
                                <div class="card-header">Distribución de Carga de Trabajo</div>
                                <div class="card-body">
                                    <div class="chart-container" style="position: relative; height: 300px;">
                                        <canvas id="workloadChart"></canvas>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- TAB 2: TASKS -->
                <div class="tab-pane fade" id="tasks" role="tabpanel">
                    <div class="row">
                        <div class="col-12">
                            <div class="glass-card">
                                <div class="card-header d-flex justify-content-between align-items-center">
                                    Tareas Activas
                                    <button class="btn btn-sm btn-primary" onclick="toggleTaskModal()">+ Agregar
                                        Tarea</button>
                                </div>
                                <div class="card-body p-0">
                                    <!-- Critical Task Lists (New) -->
                                    <div class="row g-4 mb-4">
                                        <div class="col-12 col-xl-6">
                                            <div class="task-module-container relative overflow-hidden"
                                                style="min-height: 200px;">
                                                <div
                                                    class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-red-500 to-transparent opacity-70">
                                                </div>

                                                <h3 class="text-overdue font-bold text-xl mb-6">
                                                    Tareas Vencidas
                                                </h3>

                                                <div class="task-list-container" id="overdue-tasks-list">
                                                    <!-- Injected via JS -->
                                                    <div class="text-center text-muted py-4">Cargando...</div>
                                                </div>
                                            </div>
                                        </div>

                                        <div class="col-12 col-xl-6">
                                            <div class="task-module-container relative overflow-hidden"
                                                style="min-height: 200px;">
                                                <div
                                                    class="absolute top-0 left-0 w-full h-1 bg-gradient-to-r from-blue-500 to-transparent opacity-70">
                                                </div>

                                                <h3 class="text-upcoming font-bold text-xl mb-6">
                                                    Tareas Próximas
                                                </h3>

                                                <div class="task-list-container" id="upcoming-tasks-list">
                                                    <!-- Injected via JS -->
                                                    <div class="text-center text-muted py-4">Loading...</div>
                                                </div>
                                            </div>
                                        </div>
                                    </div>

                                </div>
                            </div>
                        </div>

                        <!-- Tasks Container Removed -->
                    </div>
                </div>


                <!-- TAB 3: CAPACITY -->
                <div class="tab-pane fade" id="capacity" role="tabpanel">
                    <div class="row">
                        <div class="col-12">
                            <div id="capacity-widget" class="glass-card p-4">
                                <h3 class="text-center text-muted">Cargando Datos de Capacidad...</h3>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- TAB 4: TIME TRACKING -->
                <div class="tab-pane fade" id="tracking" role="tabpanel">
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-8">
                        <!-- 1. Log Time Form -->
                        <div class="glass-card p-6 md:col-span-1 h-fit">
                            <h2 class="text-xl font-semibold mb-6">Registrar Horas</h2>
                            <form id="log-time-form" onsubmit="event.preventDefault(); handleLogTime();">
                                <div class="form-group mb-4">
                                    <label for="time-task-select" class="form-label text-sm font-medium">Seleccionar
                                        Tarea</label>
                                    <select id="time-task-select" class="form-select premium-input" required>
                                        <option value="">Cargando tareas...</option>
                                    </select>
                                </div>
                                <div class="form-group mb-4">
                                    <label for="time-hours" class="form-label text-sm font-medium">Horas
                                        Trabajadas</label>
                                    <input type="number" id="time-hours" class="form-control premium-input"
                                        placeholder="e.g. 2.5" min="0.1" step="0.1" required>
                                </div>
                                <div class="form-group mb-4">
                                    <label for="time-date" class="form-label text-sm font-medium">Fecha</label>
                                    <input type="date" id="time-date" class="form-control premium-input" required>
                                </div>
                                <div class="form-group mb-6">
                                    <label for="time-desc" class="form-label text-sm font-medium">Notas
                                        (Opcional)</label>
                                    <textarea id="time-desc" class="form-control premium-input" rows="2"
                                        placeholder="¿En qué trabajaste?"></textarea>
                                </div>
                                <button type="submit" class="btn btn-primary w-100">Enviar Registro</button>
                            </form>
                        </div>

                        <!-- 2. Recent Activity -->
                        <div class="glass-card p-6 md:col-span-2">
                            <div class="d-flex justify-content-between align-items-center mb-4">
                                <h2 class="text-xl font-semibold">Actividad Reciente</h2>
                                <span class="text-muted small">Últimos 7 Días</span>
                            </div>
                            <div id="time-logs-container" class="space-y-4">
                                <div class="skeleton-loader skeleton-row"></div>
                                <div class="skeleton-loader skeleton-row"></div>
                                <div class="skeleton-loader skeleton-row"></div>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- TAB 5: TIMELINE (GANTT) -->
                <div class="tab-pane fade" id="timeline" role="tabpanel">
                    <div class="glass-card p-0 mt-1">
                        <div class="flex justify-between items-center mb-6">
                            <h2 class="text-xl font-semibold">Cronología del Proyecto</h2>
                            <div class="flex flex-wrap gap-3 items-center">
                                <!-- Filters -->
                                <select id="gantt-filter-project" onchange="filterGanttData()"
                                    class="form-select form-select-sm premium-input" style="width: 150px;">
                                    <option value="ALL">Todos los Proyectos</option>
                                    <!-- Populated by JS -->
                                </select>
                                <select id="gantt-filter-resource" onchange="filterGanttData()"
                                    class="form-select form-select-sm premium-input" style="width: 150px;">
                                    <option value="ALL">Todos los Recursos</option>
                                    <!-- Populated by JS -->
                                </select>

                                <div class="w-px h-6 bg-gray-200 mx-1"></div>

                                <!-- Zoom Slider -->
                                <div class="flex items-center gap-3">
                                    <span class="text-xs font-bold text-gray-500 uppercase tracking-wider">Zoom</span>
                                    <input type="range" id="gantt-zoom-slider"
                                        class="form-range w-32 h-1 bg-gray-200 rounded-lg appearance-none cursor-pointer premium-slider"
                                        min="1" max="100" value="50">
                                    <span id="gantt-zoom-label" style="min-width: 80px;">Semana</span>
                                </div>
                            </div>
                        </div>
                        <div id="gantt-chart" class="gantt-container" style="min-height: 350px;"></div>
                    </div>
                </div>

                <!-- TAB 6: SCOREBOARD -->
                <div class="tab-pane fade" id="scoreboard" role="tabpanel">
                    <!-- Section 1: Original Project Board (Tablero General) -->
                    <div class="glass-card p-0 mt-0 mb-6">
                        <h2 class="text-xl font-semibold mb-4 px-4 pt-4">Visión General de Proyectos</h2>
                        <div id="scoreboard-table-container">
                            <div class="text-center py-5 text-muted">Cargando datos del tablero...</div>
                        </div>
                    </div>

                    <!-- Section 2: My Projects (Mis Proyectos) - Moved from Talent -->
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">Mis Proyectos</h2>
                    </div>
                    <div id="kanban-projects-container">
                        <div class="text-center py-10 text-muted">
                            <i class="fas fa-circle-notch fa-spin fa-2x mb-3"></i>
                            <p>Cargando Proyectos...</p>
                        </div>
                    </div>
                </div>

                <!-- TAB 7: TALENT / PERSONAL WORKSPACE -->
                <div class="tab-pane fade" id="talent" role="tabpanel">
                    <!-- 1. HEADER: MIS SIGNOS VITALES -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-8">
                        <!-- Card 1: Velocity -->
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 relative overflow-hidden group hover:shadow-md transition-all border border-gray-100 dark:border-gray-700">
                            <div class="flex justify-between items-start mb-4">
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider">Mi Ritmo</div>
                                <div class="text-amber-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M13 10V3L4 14h7v7l9-11h-7z"></path>
                                    </svg>
                                </div>
                            </div>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-bold text-gray-900 dark:text-gray-100"
                                    id="my-velocity-value">--</span>
                                <span class="text-xs font-semibold text-gray-500">+2 vs semana anterior</span>
                            </div>
                        </div>

                        <!-- Card 2: OTD Score -->
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 relative overflow-hidden group hover:shadow-md transition-all border border-gray-100 dark:border-gray-700">
                            <div class="flex justify-between items-start mb-4">
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider">OTD Score</div>
                                <div class="text-blue-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M12 8v4l3 3m6-3a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                </div>
                            </div>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-bold text-gray-900 dark:text-gray-100"
                                    id="my-otd-value">--%</span>
                                <span class="text-xs font-semibold text-gray-500">a tiempo</span>
                            </div>
                        </div>

                        <!-- Card 3: Experience (XP) -->
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 relative overflow-hidden group hover:shadow-md transition-all border border-gray-100 dark:border-gray-700">
                            <div class="flex justify-between items-start mb-4">
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider">Experiencia (XP)
                                </div>
                                <div class="text-purple-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M11.049 2.927c.3-.921 1.603-.921 1.902 0l1.519 4.674a1 1 0 00.95.69h4.915c.969 0 1.371 1.24.588 1.81l-3.976 2.888a1 1 0 00-.363 1.118l1.518 4.674c.3.922-.755 1.688-1.538 1.118l-3.976-2.888a1 1 0 00-1.176 0l-3.976 2.888c-.783.57-1.838-.197-1.538-1.118l1.518-4.674a1 1 0 00-.363-1.118l-3.976-2.888c-.784-.57-.38-1.81.588-1.81h4.914a1 1 0 00.951-.69l1.519-4.674z">
                                        </path>
                                    </svg>
                                </div>
                            </div>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-bold text-gray-900 dark:text-gray-100"
                                    id="xp-gained">--</span>
                                <span class="text-xs font-semibold text-gray-500">Nivel 12: Code Wizard</span>
                            </div>
                        </div>
                    </div>

                    <!-- Project List moved to Tablero de Proyectos tab -->


                    <!-- SEPARATOR -->
                    <hr class="my-8 border-gray-200 dark:border-gray-700">

                    <!-- 3. TEAM OVERVIEW (Legacy / Manager View) -->
                    <div class="flex justify-between items-center mb-4">
                        <h2 class="text-xl font-semibold text-gray-800 dark:text-gray-200">Visión de Equipo</h2>
                    </div>

                    <!-- KPI Row - Resumen Style -->
                    <div class="grid grid-cols-1 md:grid-cols-3 gap-6 mb-6">
                        <!-- KPI 1: On-Time Delivery -->
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 relative overflow-hidden group hover:shadow-md transition-all border border-gray-100 dark:border-gray-700">
                            <div class="flex justify-between items-start mb-4">
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider">Entrega a Tiempo
                                    (OTD)</div>
                                <div class="text-blue-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                </div>
                            </div>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-bold text-gray-900 dark:text-gray-100"
                                    id="kpi-otd-value">--%</span>
                                <span class="text-xs font-semibold text-gray-500">Meta: >85%</span>
                            </div>
                        </div>

                        <!-- KPI 2: Overloaded Resources -->
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 relative overflow-hidden group hover:shadow-md transition-all border border-gray-100 dark:border-gray-700">
                            <div class="flex justify-between items-start mb-4">
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider">Recursos
                                    Sobrecargados</div>
                                <div class="text-red-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z">
                                        </path>
                                    </svg>
                                </div>
                            </div>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-bold text-gray-900 dark:text-gray-100"
                                    id="kpi-overloaded-value">--</span>
                                <span class="text-xs font-semibold text-gray-500">>40h asignadas</span>
                            </div>
                        </div>

                        <!-- KPI 3: Blocked Rate -->
                        <div
                            class="bg-white dark:bg-gray-800 rounded-xl shadow-sm p-6 relative overflow-hidden group hover:shadow-md transition-all border border-gray-100 dark:border-gray-700">
                            <div class="flex justify-between items-start mb-4">
                                <div class="text-xs font-bold text-gray-400 uppercase tracking-wider">Tasa de Bloqueo
                                </div>
                                <div class="text-yellow-500">
                                    <svg class="w-5 h-5" fill="none" stroke="currentColor" viewBox="0 0 24 24">
                                        <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
                                            d="M12 8v4m0 4h.01M21 12a9 9 0 11-18 0 9 9 0 0118 0z"></path>
                                    </svg>
                                </div>
                            </div>
                            <div class="flex items-baseline gap-2">
                                <span class="text-4xl font-bold text-gray-900 dark:text-gray-100"
                                    id="kpi-blocked-value">--%</span>
                                <span class="text-xs font-semibold text-gray-500">Fricción de proceso</span>
                            </div>
                        </div>
                    </div>
                    <!-- Visualizations Row -->
                    <div class="grid grid-cols-1 lg:grid-cols-2 gap-6 mb-6">
                        <!-- Chart A: Workload Heatmap Proxy (Bar Chart for now) -->
                        <div class="glass-card p-6">
                            <h4 class="text-lg font-bold text-gray-800 dark:text-white mb-4">Carga de Trabajo (Horas
                                Asignadas)</h4>
                            <div style="height: 300px;">
                                <canvas id="talent-workload-chart"></canvas>
                            </div>
                        </div>

                        <!-- Chart B: Stacked Status -->
                        <div class="glass-card p-6">
                            <h4 class="text-lg font-bold text-gray-800 dark:text-white mb-4">Estado de Tareas por
                                Recurso
                            </h4>
                            <div style="height: 300px;">
                                <canvas id="talent-stacked-chart"></canvas>
                            </div>
                        </div>
                    </div>

                    <!-- Tabla Premium RUMBO -->
                    <div class="performance-table-container">
                        <div class="table-header">
                            <h4 class="table-title">Detalle de Desempeño del Equipo</h4>
                            <div class="table-actions">
                                <button class="table-action-btn" title="Actualizar" onclick="location.reload()">
                                    <i class="fas fa-sync"></i>
                                </button>
                                <button class="table-action-btn" title="Descargar">
                                    <i class="fas fa-download"></i>
                                </button>
                                <button class="table-action-btn" title="Más opciones">
                                    <i class="fas fa-ellipsis-h"></i>
                                </button>
                            </div>
                        </div>

                        <div class="overflow-x-auto">
                            <table class="premium-table">
                                <thead>
                                    <tr>
                                        <th>Recurso</th>
                                        <th class="score-cell">OTD Score</th>
                                        <th class="metric-cell">Tareas Activas</th>
                                        <th class="metric-cell">Alta Prioridad</th>
                                        <th class="metric-cell">Horas Asig.</th>
                                        <th class="status-cell">Estado</th>
                                    </tr>
                                </thead>
                                <tbody id="talent-table-body">
                                    <!-- Rows generados por JS -->
                                </tbody>
                            </table>
                        </div>
                    </div>




                </div>
            </div>
        </div> <!-- Ends container -->
    </main>

    <!-- Task Detail Modal -->
    <div class="modal fade" id="taskDetailModal" tabindex="-1">
        <div class="modal-dialog modal-xl modal-dialog-scrollable">
            <div class="modal-content glass-card">
                <div class="modal-header border-0">
                    <h5 class="modal-title">Detalles de la Tarea</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal"></button>
                </div>
                <div class="modal-body">
                    <div class="text-center p-5">Funcionalidad en construcción</div>
                </div>
            </div>
        </div>
    </div>

    <!-- Toast Container -->
    <div id="toast-container" class="toast-container"></div>

    <!-- Modals (Simplified for Premium UI) -->
    <!-- Task Modal would also be rewritten to use glassmorphism, but for now we'll rely on JS to build it or existing functionality -->
    <div id="modal-backdrop" class="fixed inset-0 bg-black/50 hidden z-40 backdrop-blur-sm transition-opacity"
        onclick="closeModals()"></div>

    <!-- TASK DRAWER REMOVED BY ROLLBACK -->

    <!-- Scripts -->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.0/dist/js/bootstrap.bundle.min.js"></script>
    <script src="../js/api.js?v=13"></script>
    <script src="../js/navigation.js?v=13"></script>
    <script src="../js/charts.js?v=13"></script>
    <script src="../js/gantt.js?v=13"></script>
    <script src="../js/scoreboard.js?v=13"></script>
    <script src="../js/talent.js?v=13"></script>
    <!-- Add dashboard.js at the end to ensure DOM is ready -->
    <script src="../js/dashboard.js?v=13"></script>

    <!-- KPI Cards Module (ES6 Module) -->
    <script type="module">
        import KPICardsManager from '../js/kpi-cards.js';

        // Initialize KPI Cards on page load
        document.addEventListener('DOMContentLoaded', () => {
            const kpiManager = new KPICardsManager('kpi-cards-container');
            kpiManager.init();

            // Make available globally for project filter updates
            window.kpiCardsManager = kpiManager;
        });
    </script>

    <!-- PWA Service Worker Registration -->
    <script>
        if ('serviceWorker' in navigator) {
            window.addEventListener('load', () => {
                navigator.serviceWorker.register('/sw.js')
                    .then(registration => console.log('SW registered: ', registration))
                    .catch(registrationError => console.log('SW registration failed: ', registrationError));
            });
        }
    </script>

    <script>
        // Premium KPI Card definition for external use
        class PremiumKPICard {
            constructor(containerId, config) {
                const container = document.getElementById(containerId);
                if (container) {
                    container.innerHTML = `
                        <div class="glass-card premium-kpi-card hover-scale p-3 flex items-center gap-3">
                            <div class="rounded-full p-3 bg-opacity-20" style="background-color: ${config.color}20; color: ${config.color}">
                                ${config.icon}
                            </div>
                            <div>
                                <div class="text-sm text-gray-500">${config.label}</div>
                                <div class="text-2xl font-bold">${config.value}</div>
                            </div>
                        </div>
                     `;
                }
            }
        }
        window.PremiumKPICard = PremiumKPICard;
    </script>

    <!-- Add Task Modal -->
    <div class="modal fade" id="addTaskModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-lg">
            <div class="modal-content glass-card border-0">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title font-bold">Crear Nueva Tarea</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Close"></button>
                </div>
                <div class="modal-body">
                    <form id="create-task-form" onsubmit="event.preventDefault(); handleCreateTask();">
                        <div class="row g-3">
                            <div class="col-12">
                                <label for="task-title" class="form-label text-sm font-medium">Título de la
                                    Tarea</label>
                                <input type="text" id="task-title" class="form-control premium-input"
                                    placeholder="ej. Diseñar Maquetas de Página Principal" required>
                            </div>
                            <div class="col-md-6">
                                <label for="task-assignee" class="form-label text-sm font-medium">Asignar a</label>
                                <select id="task-assignee" class="form-select premium-input">
                                    <option value="Unassigned">Seleccionar Miembro del Equipo</option>
                                    <option value="Alice">Alice (Diseñadora)</option>
                                    <option value="Bob">Bob (Desarrollador)</option>
                                    <option value="Charlie">Charlie (Producto)</option>
                                    <option value="Dave">Dave (QA)</option>
                                </select>
                            </div>
                            <div class="col-md-6">
                                <label for="task-hours" class="form-label text-sm font-medium">Horas Estimadas</label>
                                <input type="number" id="task-hours" class="form-control premium-input" placeholder="0"
                                    min="0" step="0.5">
                            </div>
                            <div class="col-md-6">
                                <label for="task-start" class="form-label text-sm font-medium">Fecha de Inicio</label>
                                <input type="date" id="task-start" class="form-control premium-input">
                            </div>
                            <div class="col-md-6">
                                <label for="task-due" class="form-label text-sm font-medium">Fecha de
                                    Vencimiento</label>
                                <input type="date" id="task-due" class="form-control premium-input">
                            </div>
                            <div class="col-12">
                                <label for="task-desc" class="form-label text-sm font-medium">Descripción</label>
                                <textarea id="task-desc" class="form-control premium-input" rows="3"
                                    placeholder="Agregar detalles..."></textarea>
                            </div>
                        </div>
                        <div class="mt-4 text-end">
                            <button type="button" class="btn btn-secondary me-2"
                                data-bs-dismiss="modal">Cancelar</button>
                            <button type="submit" class="btn btn-primary">Guardar Tarea</button>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>

    <!-- Premium Kanban Functionality -->
    <script src="../js/kanban-premium.js"></script>
    <script src="../js/scoreboard.js"></script>
</body>

</html>